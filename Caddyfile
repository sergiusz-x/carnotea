# =============================================================================
# Caddy reverse proxy for CarNotea production deployment
#
# Routes:
#   https://<DOMAIN>/        → web static files (nginx container)
#   https://<DOMAIN>/api/*   → api container
#   https://<DOMAIN>/healthz → api container
#   https://<DOMAIN>/readyz  → api container
#
# DOMAIN is set via docker-compose.prod.yml or .env.
# If DOMAIN is empty/unset Caddy runs in a non-TLS "localhost" mode — fine
# for initial bring-up behind a separate LB or for testing.
# =============================================================================

{$DOMAIN:localhost} {
    # ---- API routes ---------------------------------------------------------
    handle_path /api/* {
        reverse_proxy api:3001
    }

    handle /healthz {
        reverse_proxy api:3001
    }

    handle /readyz {
        reverse_proxy api:3001
    }

    # ---- Everything else → web static bundle --------------------------------
    handle {
        reverse_proxy web:80
    }

    # ---- Logging ------------------------------------------------------------
    log {
        output file /data/logs/access.log {
            roll_size 10mb
            roll_keep 5
        }
    }
}