{
  "name": "carnotea",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "CarNotea - a vehicle diary PWA (web + mobile installable).",
  "license": "UNLICENSED",
  "prettier": "@carnotea/prettier-config",
  "packageManager": "pnpm@9.12.0",
  "pnpm": {
    "overrides": {
      "esbuild@<0.28.1": "^0.28.1",
      "brace-expansion@<1.1.16": "^1.1.16",
      "brace-expansion@>=2.0.0 <2.1.2": "^2.1.2",
      "fast-uri": "^3.1.3",
      "uuid": "^11.1.1",
      "tmp": "^0.2.4"
    }
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo watch dev --continue",
    "lint": "turbo run //#lint:root lint --continue",
    "lint:fix": "turbo run //#lint:root lint --continue -- --fix",
    "lint:root": "eslint . --cache --cache-location .cache/.eslintcache",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "gen": "turbo gen",
    "format": "turbo run //#format:root format --continue",
    "format:root": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "format:check": "turbo run //#format:check:root format:check --continue",
    "format:check:root": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "lint:ws": "sherif -r non-existant-packages",
    "lint:tickets": "node scripts/lint-tickets.mjs",
    "tickets:index": "node scripts/gen-tickets-index.mjs",
    "local:ci": "bash scripts/local-ci.sh",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "db:seed": "pnpm --filter @carnotea/db db:seed",
    "db:introspect": "turbo run db:introspect",
    "clean": "turbo run clean && rm -rf node_modules",
    "postinstall": "corepack pnpm lint:ws",
    "prepare": "husky"
  },
  "devDependencies": {
    "@carnotea/eslint-config": "workspace:*",
    "@carnotea/prettier-config": "workspace:*",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^12.0.9",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/node": "^26.1.1",
    "@types/nodemailer": "^8.0.1",
    "eslint": "catalog:",
    "husky": "^9.1.7",
    "prettier": "catalog:",
    "semantic-release": "^25.0.8",
    "sherif": "^1.13.0",
    "turbo": "^2.10.5"
  }
}
