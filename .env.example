# =============================================================================
# CarNotea environment template.
# Copy this file to `.env` for local development. Never commit `.env`.
# Each app/package only consumes variables it actually needs (see its README).
#
# Production deployment (docker-compose.prod.yml, run via Dokploy) requires
# additional vars marked [PROD]. In production these are never a file on
# disk — they're entered in Dokploy's per-application Environment Variables
# UI, which injects them at deploy time. See docs/deployment.md § Secrets
# management for the full rotation runbook.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (docker-compose postgres)
# -----------------------------------------------------------------------------
POSTGRES_DB=carnotea
POSTGRES_USER=carnotea
POSTGRES_PASSWORD=carnotea_dev_password
POSTGRES_PORT=5433

# Full DSN consumed by apps/api and packages/db.
# [PROD] When deploying, use the Docker service name as host:
#   DATABASE_URL=postgresql://carnotea:***@postgres:5432/carnotea
DATABASE_URL=postgresql://carnotea:carnotea_dev_password@localhost:5433/carnotea

# -----------------------------------------------------------------------------
# API (apps/api)
# -----------------------------------------------------------------------------
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development

# -----------------------------------------------------------------------------
# Auth (better-auth) — populated during T-006.
# [PROD] Set BETTER_AUTH_URL to https://<your-domain>
# -----------------------------------------------------------------------------
BETTER_AUTH_SECRET=replace-me-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Mailpit — local dev email preview (docker-compose mailpit service)
# Web UI: http://localhost:8025
# SMTP: localhost:1025 (no credentials needed for Mailpit)
# -----------------------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
# SMTP_USER and SMTP_PASS not required for Mailpit but can be set for real SMTP
# SMTP_USER=
# SMTP_PASS=

# Sender address shown to recipients.
EMAIL_FROM=CarNotea <noreply@localhost>
# Reply-to address (can differ from sender; used in production).
EMAIL_REPLY_TO=noreply@localhost

# [PROD] Override with your real SMTP provider:
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your-smtp-password
# EMAIL_FROM=CarNotea <noreply@carnotea.example.com>
# EMAIL_REPLY_TO=support@carnotea.example.com

# -----------------------------------------------------------------------------
# Security hardening (T-049) — defaults are dev-friendly; override for prod
# -----------------------------------------------------------------------------
# Comma-separated list of allowed CORS origins; web-app URL in prod.
# CORS_ORIGINS=https://carnotea.example.com
#
# Global rate-limit: max requests per window per IP.
# RATE_LIMIT_MAX=300
#
# Stricter limit for auth endpoints (sign-in, sign-up).
# RATE_LIMIT_AUTH_MAX=30
#
# Rate-limit time window in milliseconds (60 seconds).
# RATE_LIMIT_WINDOW_MS=60000
#
# Maximum request body size in bytes (1 MB).
# BODY_LIMIT=1048576

# -----------------------------------------------------------------------------
# Observability — OpenTelemetry (API)
# -----------------------------------------------------------------------------
# Uncomment to enable OTLP trace export. Absent → tracing disabled (no-op).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
# Overrides the default `service.name` resource attribute ('carnotea-api').
# OTEL_SERVICE_NAME=carnotea-api
# Extra comma-separated key=value resource attributes.
# OTEL_RESOURCE_ATTRIBUTES=key1=val1,key2=val2

# -----------------------------------------------------------------------------
# Observability — OpenTelemetry (Web, Vite-exposed)
# -----------------------------------------------------------------------------
# Uncomment to enable OTLP trace export from the browser. Absent → no-op.
# VITE_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# -----------------------------------------------------------------------------
# Production deployment only (docker-compose.prod.yml)
# -----------------------------------------------------------------------------
# Dokploy builds `api`/`web`/`migrate` directly from their Dockerfiles — no
# registry image or image tag needed. The public domain and TLS certificate
# are assigned to the `web` service through Dokploy's own Domains UI, not an
# env var.
#
# [PROD] Postgres backups (T-047). Store these in Dokploy's Environment
# Variables UI only; never commit real values.
# BACKUP_S3_BUCKET=car-notea-prod-backups
# BACKUP_S3_REGION=eu-central-1
# BACKUP_S3_PREFIX=carnotea/postgres
# BACKUP_S3_ENDPOINT_URL=https://s3.eu-central-1.amazonaws.com
# BACKUP_S3_SSE=AES256
# BACKUP_S3_SSE_KMS_KEY_ID=
# BACKUP_KEEP_DAILY=7
# BACKUP_KEEP_WEEKLY=8
# BACKUP_WEEKLY_DAY=7
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
