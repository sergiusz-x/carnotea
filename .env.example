# =============================================================================
# CarNotea environment template.
# Copy this file to `.env` for local development. Never commit `.env`.
# Each app/package only consumes variables it actually needs (see its README).
#
# Production deployment: copy to `.env` on the VPS, fill in real values,
# then run: docker compose -f docker-compose.prod.yml --env-file .env up -d
# =============================================================================

# -----------------------------------------------------------------------------
# Database (docker-compose postgres)
# -----------------------------------------------------------------------------
POSTGRES_DB=carnotea
POSTGRES_USER=carnotea
POSTGRES_PASSWORD=carnotea_dev_password
POSTGRES_PORT=5433

# Full DSN consumed by apps/api and packages/db.
# PRODUCTION: use the Docker service name instead of localhost:
#   postgresql://carnotea:<password>@postgres:5432/carnotea
DATABASE_URL=postgresql://carnotea:***@localhost:5433/carnotea

# -----------------------------------------------------------------------------
# API (apps/api)
# -----------------------------------------------------------------------------
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development

# -----------------------------------------------------------------------------
# Auth (better-auth)
# -----------------------------------------------------------------------------
BETTER_AUTH_SECRET=replace-me-with-openssl-rand-base64-32

# PRODUCTION: set to the public HTTPS URL where the API is reachable:
#   BETTER_AUTH_URL=https://yourserver.example.com/api/auth
BETTER_AUTH_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Web (apps/web) — only used at build time (Docker ARG)
# -----------------------------------------------------------------------------
# PRODUCTION: set to the public API URL for Caddy proxy:
#   VITE_API_URL=/api
# VITE_API_URL=/api

# -----------------------------------------------------------------------------
# Production deployment — required by docker-compose.prod.yml
# -----------------------------------------------------------------------------
# DOMAIN=your-server.example.com
