# =============================================================================
# CarNotea environment template.
# Copy this file to `.env` for local development. Never commit `.env`.
# Each app/package only consumes variables it actually needs (see its README).
#
# Production deployment (docker-compose.prod.yml) requires additional vars
# marked [PROD]. See docs/deployment.md for the full walk-through.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (docker-compose postgres)
# -----------------------------------------------------------------------------
POSTGRES_DB=carnotea
POSTGRES_USER=carnotea
POSTGRES_PASSWORD=carnotea_dev_password
POSTGRES_PORT=5433

# Full DSN consumed by apps/api and packages/db.
# [PROD] When deploying, use the Docker service name as host:
#   DATABASE_URL=postgresql://carnotea:***@postgres:5432/carnotea
DATABASE_URL=postgresql://carnotea:carnotea_dev_password@localhost:5433/carnotea

# -----------------------------------------------------------------------------
# API (apps/api)
# -----------------------------------------------------------------------------
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development

# -----------------------------------------------------------------------------
# Auth (better-auth) — populated during T-006.
# [PROD] Set BETTER_AUTH_URL to https://<your-domain>
# -----------------------------------------------------------------------------
BETTER_AUTH_SECRET=replace-me-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Security hardening (T-049) — defaults are dev-friendly; override for prod
# -----------------------------------------------------------------------------
# Comma-separated list of allowed CORS origins; web-app URL in prod.
# CORS_ORIGINS=https://carnotea.example.com
#
# Global rate-limit: max requests per window per IP.
# RATE_LIMIT_MAX=100
#
# Stricter limit for auth endpoints (sign-in, sign-up).
# RATE_LIMIT_AUTH_MAX=10
#
# Rate-limit time window in milliseconds (60 seconds).
# RATE_LIMIT_WINDOW_MS=60000
#
# Maximum request body size in bytes (1 MB).
# BODY_LIMIT=1048576

# -----------------------------------------------------------------------------
# Production deployment only (docker-compose.prod.yml)
# -----------------------------------------------------------------------------
# [PROD] Required. Domain for Caddy TLS certificate.
# DOMAIN=carnotea.example.com
