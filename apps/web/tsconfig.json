{
  "extends": "@carnotea/tsconfig/react.json",
  "compilerOptions": {
    "noEmit": true,
    "paths": {
      "@/components/*": ["./src/components/*"],
      "@/features/*": ["./src/features/*"],
      "@/lib/*": ["./src/lib/*"],
      "@/offline/*": ["./src/offline/*"],
      "@/offline": ["./src/offline/index"],
      "@/routes/*": ["./src/routes/*"]
    }
  },
  "include": [
    "src",
    "vite.config.ts",
    "vitest.config.ts",
    "vitest.setup.ts",
    "e2e/**/*",
    "playwright.config.ts"
  ]
}
