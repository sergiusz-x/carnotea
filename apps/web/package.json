{
  "name": "@carnotea/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "codegen:api": "node scripts/generate-api-schema.mjs http://localhost:3001/openapi.json src/lib/api/schema.d.ts",
    "codegen:api:check": "pnpm codegen:api && git diff --exit-code -- src/lib/api/schema.d.ts",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --cache --cache-location .cache/.eslintcache",
    "format": "prettier --write . --ignore-path ../../.prettierignore",
    "format:check": "prettier --check . --ignore-path ../../.prettierignore",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@carnotea/shared": "workspace:*",
    "@hookform/resolvers": "catalog:",
    "@opentelemetry/auto-instrumentations-web": "^0.65.0",
    "@opentelemetry/core": "^2.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/instrumentation": "^0.220.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-trace-web": "^2.9.0",
    "@opentelemetry/semantic-conventions": "^1.43.0",
    "@radix-ui/react-dialog": "^1.1.20",
    "@radix-ui/react-dropdown-menu": "^2.1.21",
    "@radix-ui/react-label": "catalog:",
    "@radix-ui/react-select": "^2.3.4",
    "@radix-ui/react-slot": "catalog:",
    "@tanstack/query-sync-storage-persister": "^5.101.3",
    "@tanstack/react-query": "catalog:",
    "@tanstack/react-query-persist-client": "^5.101.3",
    "@tanstack/react-router": "catalog:",
    "better-auth": "catalog:",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "i18next": "catalog:",
    "i18next-browser-languagedetector": "catalog:",
    "lucide-react": "catalog:",
    "react": "catalog:react19",
    "react-dom": "catalog:react19",
    "react-hook-form": "catalog:",
    "react-i18next": "catalog:",
    "tailwind-merge": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@carnotea/eslint-config": "workspace:*",
    "@carnotea/prettier-config": "workspace:*",
    "@carnotea/tsconfig": "workspace:*",
    "@carnotea/vitest-config": "workspace:*",
    "@tailwindcss/vite": "catalog:",
    "@tanstack/react-query-devtools": "catalog:",
    "@tanstack/react-router-devtools": "catalog:",
    "@testing-library/dom": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/react": "catalog:react19",
    "@types/react-dom": "catalog:react19",
    "@vitejs/plugin-react": "catalog:",
    "eslint": "catalog:",
    "jsdom": "catalog:",
    "prettier": "catalog:",
    "sharp": "^0.35.3",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-pwa": "1.3.0",
    "vitest": "catalog:"
  },
  "prettier": "@carnotea/prettier-config"
}
