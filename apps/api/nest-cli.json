{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "builder": {
      "type": "swc",
      "options": {
        "stripLeadingPaths": true,
        "ignore": ["**/*.test.ts", "**/*.spec.ts"]
      }
    },
    "assets": ["emails/locales/**/*.json"],
    "watchAssets": true,
    "typeCheck": true,
    "deleteOutDir": true
  }
}
